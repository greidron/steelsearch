{
  "setup": [
    {
      "method": "DELETE",
      "path": "/logs-stateful-probe?ignore_unavailable=true"
    },
    {
      "method": "PUT",
      "path": "/logs-stateful-probe",
      "body": {
        "settings": {
          "index.number_of_shards": 1,
          "index.number_of_replicas": 0
        },
        "mappings": {
          "properties": {
            "message": {
              "type": "text"
            },
            "tenant": {
              "type": "keyword"
            }
          }
        }
      }
    },
    {
      "method": "PUT",
      "path": "/logs-stateful-probe/_doc/doc-1?refresh=true",
      "body": {
        "message": "stateful route probe",
        "tenant": "tenant-a"
      }
    }
  ],
  "cases": [
    {
      "name": "allocation_explain_get",
      "family": "root-cluster-node",
      "inventory_path": "/_cluster/allocation/explain",
      "method": "GET",
      "path": "/_cluster/allocation/explain",
      "expected_runtime_status": "stateful-route-present"
    },
    {
      "name": "allocation_explain_post",
      "family": "root-cluster-node",
      "inventory_path": "/_cluster/allocation/explain",
      "method": "POST",
      "path": "/_cluster/allocation/explain",
      "body": {
        "index": "logs-stateful-probe",
        "shard": 0,
        "primary": true
      },
      "expected_runtime_status": "stateful-route-present"
    },
    {
      "name": "cluster_settings_put",
      "family": "root-cluster-node",
      "inventory_path": "/_cluster/settings",
      "method": "PUT",
      "path": "/_cluster/settings",
      "body": {
        "persistent": {
          "cluster.routing.allocation.enable": "all"
        }
      },
      "expected_runtime_status": "stateful-route-present"
    },
    {
      "name": "index_create_put",
      "family": "index-and-metadata",
      "inventory_path": "/{index}",
      "method": "PUT",
      "path": "/logs-stateful-created",
      "body": {
        "settings": {
          "index.number_of_shards": 1,
          "index.number_of_replicas": 0
        }
      },
      "expected_runtime_status": "stateful-route-present"
    },
    {
      "name": "bulk_post",
      "family": "document-and-bulk",
      "inventory_path": "/{index}/_bulk",
      "method": "POST",
      "path": "/logs-stateful-probe/_bulk",
      "raw_body": "{\"index\":{\"_id\":\"doc-2\"}}\n{\"message\":\"bulk probe\",\"tenant\":\"tenant-a\"}\n",
      "content_type": "application/x-ndjson",
      "expected_runtime_status": "stateful-route-present"
    },
    {
      "name": "search_post",
      "family": "search",
      "inventory_path": "/{index}/_search",
      "method": "POST",
      "path": "/logs-stateful-probe/_search",
      "body": {
        "query": {
          "match_all": {}
        }
      },
      "expected_runtime_status": "stateful-route-present"
    },
    {
      "name": "snapshot_repository_put",
      "family": "snapshot-migration-interop",
      "inventory_path": "/_snapshot/{repository}",
      "method": "PUT",
      "path": "/_snapshot/repo-stateful-probe",
      "body": {
        "type": "fs",
        "settings": {
          "location": "/tmp/steelsearch-stateful-probe-repo"
        }
      },
      "expected_runtime_status": "stateful-route-present"
    },
    {
      "name": "tasks_cancel_post",
      "family": "root-cluster-node",
      "inventory_path": "/_tasks/_cancel",
      "method": "POST",
      "path": "/_tasks/_cancel",
      "body": {},
      "expected_runtime_status": "stateful-route-present"
    },
    {
      "name": "knn_model_train_post",
      "family": "vector-and-ml",
      "inventory_path": "String.format(Locale.ROOT, \"%s/%s/_train\", KNNPlugin.KNN_BASE_URI, MODELS)",
      "method": "POST",
      "path": "/_plugins/_knn/models/_train",
      "body": {
        "model_id": "probe-model",
        "training_index": "logs-stateful-probe",
        "training_field": "tenant"
      },
      "expected_runtime_status": "stateful-route-present"
    }
  ]
}
