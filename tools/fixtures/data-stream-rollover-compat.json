{
  "name": "data-stream-rollover-compat",
  "cases": [
    {
      "name": "get_data_stream_global_fail_closed_vs_opensearch_supported",
      "method": "GET",
      "path": "/_data_stream",
      "steelsearch_compare": {
        "expected_status": 400,
        "body_paths_present": [
          "error.type",
          "error.reason",
          "status"
        ]
      },
      "opensearch_compare": {
        "expected_status": 200,
        "body_paths_present": [
          "data_streams"
        ]
      }
    },
