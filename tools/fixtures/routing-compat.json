        ],
        "body_paths_equal": [
          "hits.total.value"
        ]
      }
    },
    {
      "name": "create_alias_routing_indices",
      "method": "POST",
      "path": "/_aliases",
      "setup": [
        {
          "method": "PUT",
          "path": "/routing-alias-000001",
          "body": {}
        },
        {
          "method": "PUT",
          "path": "/routing-alias-000002",
          "body": {}
        }
      ],
      "body": {
        "actions": [
          {
            "add": {
              "index": "routing-alias-000001",
              "alias": "routing-write",
              "is_write_index": true,
              "routing": "tenant-a"
            }
          },
          {
            "add": {
              "index": "routing-alias-000002",
              "alias": "routing-search",
              "search_routing": "tenant-b"
            }
          }
        ]
      },
      "compare": {
        "expected_status": 200
      }
    },
