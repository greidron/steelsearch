{
  "name": "routing-compat",
  "cases": [
    {
      "name": "create_routing_compat_index",
      "method": "PUT",
      "path": "/routing-compat-000001",
      "setup": [
        {
          "method": "DELETE",
          "path": "/routing-compat-000001,routing-alias-000001,routing-alias-000002?ignore_unavailable=true"
        }
      ],
      "body": {},
      "compare": {
        "expected_status": 200
      }
    },
    {
      "name": "put_routed_document",
      "method": "PUT",
      "path": "/routing-compat-000001/_doc/doc-1?routing=tenant-a",
      "body": {
        "message": "tenant-a-doc"
      },
      "compare": {
        "expected_status": 201,
        "body_paths_present": [
          "_index",
          "_id",
          "result"
        ],
        "body_paths_equal": [
          "_index",
          "_id",
          "result"
        ]
      }
    },
    {
      "name": "get_routed_document_with_matching_routing",
      "method": "GET",
      "path": "/routing-compat-000001/_doc/doc-1?routing=tenant-a",
      "compare": {
        "expected_status": 200,
        "body_paths_present": [
          "_index",
          "_id",
          "found",
          "_source.message"
        ],
        "body_paths_equal": [
          "_index",
          "_id",
          "found",
          "_source.message"
        ]
      }
    },
    {
      "name": "get_routed_document_without_routing_misses",
      "method": "GET",
      "path": "/routing-compat-000001/_doc/doc-1",
      "compare": {
        "expected_status": 200,
        "body_paths_present": [
          "_index",
          "_id",
          "found"
        ],
        "body_paths_equal": [
          "_index",
          "_id",
          "found"
        ]
      }
    },
    {
      "name": "search_routed_document_with_matching_routing",
      "method": "GET",
      "path": "/routing-compat-000001/_search?routing=tenant-a",
      "body": {
        "query": {
          "term": {
            "message": "tenant-a-doc"
          }
        }
      },
      "compare": {
        "expected_status": 200,
        "body_paths_present": [
          "hits.total.value"
        ],
        "body_paths_absent": [
          "hits.hits.0._id"
        ],
        "body_paths_equal": [
          "hits.total.value"
        ]
      }
    },
    {
      "name": "search_routed_document_with_wrong_routing_is_empty",
      "method": "GET",
      "path": "/routing-compat-000001/_search?routing=tenant-b",
      "body": {
        "query": {
          "term": {
            "message": "tenant-a-doc"
          }
