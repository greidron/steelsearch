{
  "name": "allocation-explain-compat",
  "setup": [
    {
      "name": "seed_logs_compat_index",
      "method": "PUT",
      "path": "/logs-compat",
      "compare": {
        "expected_status": 200
      }
    }
  ],
  "cases": [
    {
      "name": "allocation_explain_primary_happy_path",
      "method": "POST",
      "path": "/_cluster/allocation/explain",
      "body": {
        "index": "logs-compat",
        "shard": 0,
        "primary": true
      },
      "compare": {
        "expected_status": 200,
        "body_paths_present": [
          "index",
          "shard",
          "primary",
          "current_state",
          "can_remain_on_current_node",
          "can_rebalance_cluster",
          "can_rebalance_to_other_node",
          "rebalance_explanation",
          "current_node.id",
          "current_node.name",
          "current_node.transport_address",
          "current_node.weight_ranking",
          "current_node.attributes"
        ],
        "body_paths_equal": [
          "index",
          "shard",
          "primary",
          "current_state",
          "can_remain_on_current_node",
          "can_rebalance_cluster",
          "can_rebalance_to_other_node",
          "rebalance_explanation"
        ]
      }
    },
    {
      "name": "allocation_explain_replica_unassigned_path",
      "method": "POST",
      "path": "/_cluster/allocation/explain",
      "body": {
        "index": "logs-compat",
        "shard": 0,
        "primary": false
      },
      "compare": {
        "expected_status": 200,
        "body_paths_present": [
          "index",
          "shard",
          "primary",
          "current_state",
          "can_allocate",
          "allocate_explanation",
          "unassigned_info.reason",
          "unassigned_info.last_allocation_status",
          "node_allocation_decisions"
        ],
        "body_paths_equal": [
          "index",
          "shard",
          "primary",
          "current_state",
          "can_allocate",
          "allocate_explanation",
          "unassigned_info.reason",
          "unassigned_info.last_allocation_status"
        ]
      }
    }
  ]
}
