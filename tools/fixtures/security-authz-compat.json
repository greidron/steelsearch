{
  "name": "security-authz-compat",
  "description": "Secure standalone authn/authz compatibility fixture for 401/403 envelope parity and minimum-role route checks.",
  "policy": "tools/fixtures/security-bootstrap-policy.json",
  "setup_credential_set": "admin-basic",
  "profiles": [
    "single-node-secure",
    "multi-node-secure"
  ],
  "indices": [
    {
      "name": "logs-security-authz-000001",
      "body": {
        "mappings": {
          "properties": {
            "message": {
              "type": "text"
            },
            "tenant": {
              "type": "keyword"
            }
          }
        }
      }
    },
    {
      "name": ".opensearch-restricted-alias-authz-000001",
      "body": {
        "mappings": {
          "properties": {
            "message": {
              "type": "text"
            },
            "tenant": {
              "type": "keyword"
            }
          }
        }
      }
    }
  ],
  "bulk": [
    {
      "index": "logs-security-authz-000001",
      "documents": [
        {
          "_id": "authz-doc-1",
          "_source": {
            "message": "secured log doc",
            "tenant": "tenant-authz"
          }
        }
      ]
    },
    {
      "index": ".opensearch-restricted-alias-authz-000001",
      "documents": [
        {
          "_id": "authz-restricted-doc-1",
          "_source": {
            "message": "restricted alias doc",
            "tenant": "tenant-authz"
          }
        }
      ]
    }
  ],
  "aliases": [
    {
      "index": ".opensearch-restricted-alias-authz-000001",
      "alias": "restricted-authz-alias"
    }
  ],
  "credential_sets": {
    "missing": {
      "mode": "no-auth-header"
    },
    "wrong-basic": {
      "mode": "basic-auth",
      "username_env": "SECURITY_INVALID_USERNAME",
      "password_env": "SECURITY_INVALID_PASSWORD"
    },
    "admin-basic": {
      "mode": "basic-auth",
      "username_env": "SECURITY_ADMIN_USERNAME",
      "password_env": "SECURITY_ADMIN_PASSWORD"
    },
    "reader-basic": {
      "mode": "basic-auth",
      "username_env": "SECURITY_READER_USERNAME",
      "password_env": "SECURITY_READER_PASSWORD"
    },
    "writer-basic": {
      "mode": "basic-auth",
      "username_env": "SECURITY_WRITER_USERNAME",
      "password_env": "SECURITY_WRITER_PASSWORD"
    }
  },
  "case_buckets": [
    "missing-credential-401",
    "wrong-credential-401",
    "insufficient-role-403",
    "minimum-role-success"
  ],
  "cases": [
    {
      "name": "security_missing_root_cluster_read_401",
      "area": "security-authz",
      "bucket": "missing-credential-401",
      "method": "GET",
      "path": "/_cluster/health",
      "credential_set": "missing",
      "extract": "security_error",
      "family": "security-authz",
      "description": "[missing-credential-401] root cluster read requires auth"
    },
    {
      "name": "security_missing_header_index_read_401",
      "area": "security-authz",
      "bucket": "missing-credential-401",
      "method": "GET",
      "path": "/logs-security-authz-000001/_search",
      "credential_set": "missing",
      "extract": "security_error",
      "family": "security-authz",
      "description": "[missing-credential-401] index read fails when auth header is absent"
    },
    {
