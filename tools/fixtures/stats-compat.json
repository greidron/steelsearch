{
  "name": "stats-compat",
  "setup": [
    {
      "name": "create_logs_stats_compat_index",
      "method": "PUT",
      "path": "/logs-stats-compat",
      "compare": {
        "expected_status": 200,
        "body_paths_present": [
          "acknowledged",
          "index"
        ],
        "body_paths_equal": [
          "acknowledged",
          "index"
        ]
      }
    }
  ],
  "cases": [
    {
      "name": "get_nodes_stats_shape",
      "method": "GET",
      "path": "/_nodes/stats",
      "compare": {
        "expected_status": 200,
        "body_paths_present": [
          "nodes"
        ],
        "compare_mode": "nodes_stats_shape"
      }
    },
    {
      "name": "get_cluster_stats_shape_and_numeric_subset",
      "method": "GET",
      "path": "/_cluster/stats",
      "compare": {
        "expected_status": 200,
        "body_paths_present": [
          "cluster_name",
          "status",
          "indices",
          "indices.docs",
          "indices.shards.total",
          "nodes",
          "nodes.count",
          "nodes.count.total",
          "nodes.count.data"
        ],
        "body_paths_equal": [
          "nodes.count.total"
        ]
      }
    },
    {
      "name": "get_index_stats_shape_and_numeric_subset",
      "method": "GET",
      "path": "/_stats",
      "compare": {
        "expected_status": 200,
        "body_paths_present": [
          "_shards",
          "_shards.total",
          "_shards.successful",
          "_shards.failed",
          "_all",
          "_all.primaries",
          "_all.primaries.docs",
          "_all.primaries.docs.count",
          "_all.total",
          "_all.total.docs",
          "_all.total.docs.count",
          "indices",
          "indices.logs-stats-compat",
          "indices.logs-stats-compat.primaries.docs.count",
          "indices.logs-stats-compat.total.docs.count"
        ],
        "body_paths_equal": [
          "_all.total.docs.count"
        ]
      }
    }
  ]
}
