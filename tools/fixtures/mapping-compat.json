{
  "name": "mapping-compat",
  "cases": [
    {
      "name": "create_index_for_mapping_cases",
      "method": "PUT",
      "path": "/logs-compat-mapping-000001",
      "setup": [
        {
          "method": "DELETE",
          "path": "/logs-compat-mapping-000001?ignore_unavailable=true"
        }
      ],
      "body": {
        "mappings": {
          "dynamic": "strict",
          "_meta": {
            "owner": "search"
          },
          "properties": {
            "message": {
              "type": "text"
            }
          }
        }
      },
      "compare": {
        "expected_status": 200
      }
    },
    {
      "name": "get_mapping_happy_path",
      "method": "GET",
      "path": "/logs-compat-mapping-000001/_mapping",
      "compare": {
        "expected_status": 200,
        "body_paths_present": [
          "logs-compat-mapping-000001.mappings.properties.message.type",
          "logs-compat-mapping-000001.mappings.dynamic",
          "logs-compat-mapping-000001.mappings._meta.owner"
        ]
      }
    },
    {
      "name": "put_mapping_merge_dynamic_meta_and_properties",
      "method": "PUT",
      "path": "/logs-compat-mapping-000001/_mapping",
      "body": {
        "dynamic": "false",
        "_meta": {
          "owner": "platform",
          "rollout": "phase-a1"
        },
        "properties": {
          "level": {
            "type": "keyword"
          }
        }
      },
      "compare": {
        "expected_status": 200
      }
    },
    {
      "name": "get_mapping_after_update",
      "method": "GET",
      "path": "/logs-compat-mapping-000001/_mapping",
      "compare": {
        "expected_status": 200,
        "body_paths_present": [
          "logs-compat-mapping-000001.mappings.properties.level.type",
          "logs-compat-mapping-000001.mappings.dynamic",
          "logs-compat-mapping-000001.mappings._meta.owner",
          "logs-compat-mapping-000001.mappings._meta.rollout"
        ],
        "body_paths_equal": [
          "logs-compat-mapping-000001.mappings.properties.level.type",
          "logs-compat-mapping-000001.mappings.dynamic",
          "logs-compat-mapping-000001.mappings._meta.owner",
          "logs-compat-mapping-000001.mappings._meta.rollout"
        ]
      }
    },
    {
      "name": "put_mapping_incompatible_update_failure",
      "method": "PUT",
      "path": "/logs-compat-mapping-000001/_mapping",
      "body": {
        "properties": {
          "message": {
            "type": "long"
          }
        }
      },
      "compare": {
        "expected_status": 400,
        "body_paths_present": [
          "error.type",
          "error.reason",
          "status"
        ],
        "body_paths_equal": [
          "error.type"
        ]
      }
    }
  ]
}
