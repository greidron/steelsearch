{
  "name": "cluster-health-compat",
  "setup": [
    {
      "name": "seed_logs_health_index",
      "method": "PUT",
      "path": "/logs-health-compat"
    }
  ],
  "cases": [
    {
      "name": "get_cluster_health_top_level_summary",
      "method": "GET",
      "path": "/_cluster/health",
      "compare": {
        "expected_status": 200,
        "body_paths_present": [
          "status",
          "timed_out",
          "number_of_nodes",
          "active_primary_shards",
          "active_shards",
          "unassigned_shards"
        ],
        "body_paths_equal": [
          "status",
          "timed_out",
          "number_of_nodes",
          "active_primary_shards",
          "active_shards",
          "unassigned_shards"
        ]
      }
    },
    {
      "name": "wait_for_status_green",
      "method": "GET",
      "path": "/_cluster/health?wait_for_status=green&timeout=1s",
      "compare": {
        "expected_status": 408,
        "body_exact": {
          "status": "yellow",
          "timed_out": true
        },
        "body_paths_equal": [
          "status",
          "timed_out"
        ]
      }
    },
    {
      "name": "wait_for_nodes_timeout",
      "method": "GET",
      "path": "/_cluster/health?wait_for_nodes=%3E%3D2&timeout=0s",
      "compare": {
        "expected_status": 408,
        "body_exact": {
          "timed_out": true
        },
        "body_paths_equal": [
          "timed_out",
          "number_of_nodes"
        ]
      }
    },
    {
      "name": "index_scoped_health_existing_index",
      "method": "GET",
      "path": "/_cluster/health/logs-health-compat",
      "compare": {
        "expected_status": 200,
        "body_exact": {
          "status": "yellow",
          "timed_out": false
        },
        "body_paths_equal": [
          "status",
          "timed_out",
          "active_primary_shards",
          "active_shards",
          "unassigned_shards"
        ]
      }
    },
    {
      "name": "index_scoped_wait_for_green_timeout",
      "method": "GET",
      "path": "/_cluster/health/logs-health-compat?wait_for_status=green&timeout=0s",
      "compare": {
        "expected_status": 408,
        "body_exact": {
          "status": "yellow",
          "timed_out": true
        },
        "body_paths_equal": [
          "status",
          "timed_out"
        ]
      }
    }
  ]
}
